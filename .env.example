# Cisco Identity Services Engine (ISE) connection settings.
# Copy to .env and fill in. Never commit .env.
ISE_URL=https://192.0.2.30
ISE_USERNAME=admin
ISE_PASSWORD=changeme
# ERS is served on port 443 (modern, recommended) and the legacy 9060 (deprecated
# in ISE 3.x, often off/firewalled). Default 443; set 9060 only for old ISE.
# ERS must still be enabled in the GUI: Admin > System > Settings > API Settings.
ISE_ERS_PORT=443
# Verify the ISE TLS certificate (labs usually use self-signed).
ISE_VERIFY_SSL=false
# Per-request timeout in seconds.
ISE_TIMEOUT=60
